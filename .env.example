# Variables de entorno para el Agente ECF
# Copiar a .env y ajustar valores

# Autenticación API TekServices (API Key)
ECF_API_KEY=your_api_key_here

# Entorno (DEV, CERT, PROD)
ECF_ENVIRONMENT=DEV

# Contraseña de la base de datos
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_db_name
DB_USER=your_db_username
DB_PASSWORD=your_db_password
